    </attributes>
    <function name="Main" type="None" variable="">
        <parameters/>
        <body>
            <declare name="alumnos, i, j, salones, totalAlumnos" type="Integer" array="False" size=""/>
            <declare name="promSalon, promGlobal, sumaNotasSalon, nota, sumaGlobal" type="Real" array="False" size=""/>
            <assign variable="sumaGlobal" expression="0"/>
            <assign variable="totalAlumnos" expression="0"/>
            <output expression="&quot;ingrese numero de salones&quot;" newline="True"/>
            <input variable="salones"/>
            <for variable="i" start="1" end="salones" direction="inc" step="1">
                <assign variable="sumaNotasSalon" expression="0"/>
                <output expression="&quot;Ingrese  alumnos de este salon&quot;" newline="True"/>
                <input variable="alumnos"/>
                <for variable="j" start="1" end="alumnos" direction="inc" step="1">
                    <output expression="&quot;ingrese nota del estudiante&quot;" newline="True"/>
                    <input variable="nota"/>
                    <assign variable="sumaNotasSalon" expression="sumaNotasSalon+nota"/>
                    <assign variable="sumaGlobal" expression="sumaGlobal+nota"/>
                    <assign variable="totalAlumnos" expression="totalAlumnos+1"/>
                </for>
                <assign variable="promSalon" expression="sumaNotasSalon/alumnos"/>
                <output expression="&quot;promedio del salon es &quot;&amp;promSalon" newline="True"/>
            </for>
            <assign variable="promGlobal" expression="sumaGlobal/totalAlumnos"/>
            <output expression="&quot;promedio global es &quot;&amp;promGlobal" newline="True"/>
        </body>
    </function>
</flowgorithm>
